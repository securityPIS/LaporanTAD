# LaporanTAD — environment variables (ARSITEKTUR §11).
# Salin ke .env.local untuk pengembangan. Tanpa nilai ini, aplikasi berjalan
# dalam mode dev/demo (data in-memory + login dev), berguna untuk uji cepat.

# Auth.js
AUTH_SECRET=                 # openssl rand -base64 32
AUTH_GOOGLE_ID=              # OAuth Client ID (Google Cloud Console)
AUTH_GOOGLE_SECRET=          # OAuth Client Secret

# Service account (Google Sheets + Drive)
GOOGLE_SA_EMAIL=             # email service account
GOOGLE_SA_PRIVATE_KEY=       # private key (escape \n sebagai \\n)
SHEETS_DATABASE_ID=          # ID spreadsheet database
DRIVE_ROOT_FOLDER_ID=        # ID folder LaporanTAD/

# Google Apps Script (docgen + cron)
GAS_WEBAPP_URL=              # URL deployment Web App GAS
GAS_SHARED_SECRET=           # secret bersama Vercel↔GAS

# Penunjukan admin awal (opsional, dipisah koma). Email di sini otomatis
# diperlakukan sebagai admin meski data users belum di-set.
ADMIN_EMAILS=
